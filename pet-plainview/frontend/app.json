{
  "expo": {
    "name": "What If My Pet Was",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "whatifmypet",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergent.petalternatelife.yycvma",
      "infoPlist": {
        "NSCameraUsageDescription": "Snap a pet photo to transform",
        "NSPhotoLibraryUsageDescription": "Pick a pet photo to transform",
        "NSPhotoLibraryAddUsageDescription": "Save your pet transformations"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emergent.petalternatelife.yycvma",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Pick a pet photo to transform",
          "cameraPermission": "Take a pet photo to transform"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
